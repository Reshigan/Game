# =============================================================================
# Word Cloud Analytics Platform - Environment Configuration
# =============================================================================
# Copy this file to .env.local (for local development) or .env.production
# Documentation: https://docs.wordcloud-analytics.com/configuration
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Word Cloud Analytics"
NEXT_PUBLIC_API_VERSION=1.0
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL with TimescaleDB)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/wordcloud?sslmode=disable
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=true
DATABASE_CA_CERT=

# -----------------------------------------------------------------------------
# REDIS CACHE (Upstash or self-hosted)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# AUTHENTICATION (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-min-32-characters-long-change-me
AUTH_PROVIDER=nextauth
AUTH_SESSION_MAX_AGE=2592000
AUTH_SESSION_UPDATE_AGE=86400

# OAuth Providers (optional)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# Credentials Auth (optional)
AUTH_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# STORAGE (Vercel Blob or S3-compatible)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=vercel-blob
BLOB_READ_WRITE_TOKEN=

# For S3-compatible storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ANALYTICS_ID=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_ANALYTICS_MAX=1000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID,X-Idempotency-Key
CORS_MAX_AGE=86400

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
SECURITY_HEADERS_ENABLED=true
CSP_REPORT_URI=
HSTS_MAX_AGE=31536000

# -----------------------------------------------------------------------------
# BILLING (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Billing Plans
PLAN_FREE_LIMIT=100
PLAN_PRO_LIMIT=10000
PLAN_ENTERPRISE_LIMIT=unlimited

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_WORD_CLOUD_EXPORTS=true
FEATURE_ANALYTICS_DASHBOARD=true
FEATURE_TEAM_COLLABORATION=false
FEATURE_EMBED_WIDGET=true
FEATURE_VERSION_HISTORY=false

# -----------------------------------------------------------------------------
# ALERTING
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
ALERT_EMAIL=

# -----------------------------------------------------------------------------
# MULTI-TENANCY
# -----------------------------------------------------------------------------
MULTI_TENANT_ENABLED=true
DEFAULT_TENANT_PLAN=free

# -----------------------------------------------------------------------------
# DATA RETENTION
# -----------------------------------------------------------------------------
DATA_RETENTION_DAYS=90
ANALYTICS_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# BACKUP & RECOVERY
# -----------------------------------------------------------------------------
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30