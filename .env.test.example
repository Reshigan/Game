# .env.test.example
# =============================================================================
# WORD CLOUD ANALYTICS PLATFORM - TEST ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.test for running integration tests
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=test
PORT=3001
API_VERSION=1.0
APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# DATABASE (Test Database)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://test_user:test_password@localhost:5432/wordcloud_test?schema=public
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
DATABASE_SSL=false

# -----------------------------------------------------------------------------
# REDIS (Test Cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# JWT SECRETS (Test Only - MUST be at least 32 characters)
# CRITICAL: These are for TEST ENVIRONMENT ONLY
# Production secrets MUST be set via secure secrets manager
# -----------------------------------------------------------------------------
TEST_JWT_SECRET=test_jwt_secret_minimum_32_characters_for_security
TEST_REFRESH_SECRET=test_refresh_secret_minimum_32_characters_for_security

# Production secrets (used by application)
JWT_SECRET=production_jwt_secret_minimum_32_characters_DO_NOT_USE_IN_PROD
JWT_REFRESH_SECRET=production_refresh_secret_minimum_32_characters_DO_NOT_USE_IN_PROD
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CLICKHOUSE (Test Analytics)
# -----------------------------------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=wordcloud_analytics_test

# -----------------------------------------------------------------------------
# STORAGE (Test Storage)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_BUCKET=word-cloud-test

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty