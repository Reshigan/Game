# =============================================================================
# WORD CLOUD ANALYTICS PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
# This file documents all required environment variables.
# Copy to .env and fill in values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development|staging|production
PORT=3000
API_VERSION=1.0
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/wordcloud?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# -----------------------------------------------------------------------------
# REDIS (Cache & Sessions)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# CLICKHOUSE (Analytics)
# -----------------------------------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=wordcloud_analytics

# -----------------------------------------------------------------------------
# STORAGE (S3-Compatible)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=s3|minio|r2
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret-key
STORAGE_BUCKET=word-cloud-exports
STORAGE_CDN_URL=https://cdn.example.com

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
AUTH_PROVIDER=local|oauth
JWT_SECRET=your-jwt-secret-min-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OAuth - Google
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# OAuth - GitHub
OAUTH_GITHUB_CLIENT_ID=your-github-client-id
OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret
OAUTH_GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# -----------------------------------------------------------------------------
# BILLING (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Pricing tiers (cents)
STRIPE_FREE_PRICE_ID=price_free
STRIPE_PRO_PRICE_ID=price_pro
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise

# -----------------------------------------------------------------------------
# EMAIL SERVICE
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=sendgrid|ses|smtp
EMAIL_FROM=noreply@example.com
EMAIL_API_KEY=your-email-api-key

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_WORD_CLOUD_EXPORTS=true
FEATURE_ANALYTICS_DASHBOARD=true
FEATURE_EMBED_WIDGET=true
FEATURE_VERSION_HISTORY=false

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug|info|warn|error
LOG_FORMAT=json|pretty

# -----------------------------------------------------------------------------
# ALERTING
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx
ALERT_EMAIL=alerts@example.com

# -----------------------------------------------------------------------------
# CDN
# -----------------------------------------------------------------------------
CDN_BASE_URL=https://cdn.example.com

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-min-32-characters
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict|lax|none

# -----------------------------------------------------------------------------
# DATA RETENTION (Days)
# -----------------------------------------------------------------------------
DATA_RETENTION_CLICK_EVENTS=365
DATA_RETENTION_AUDIT_LOGS=90
DATA_RETENTION_EXPORTS=30